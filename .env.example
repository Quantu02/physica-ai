# PhysicaAI — Environment Variables
# =====================================
# Copy this file to .env.local for local development
# In production, add these in Vercel Dashboard → Settings → Environment Variables

# YOUR GEMINI API KEY
# Get it free at: https://aistudio.google.com/app/apikey
# Click "Create API Key" → Copy the key (starts with "AIza...")
GEMINI_API_KEY=AIzaSy-YOUR_KEY_HERE

# ⚠️  NEVER commit your real API key to Git
# ⚠️  The .env.local file is already in .gitignore
